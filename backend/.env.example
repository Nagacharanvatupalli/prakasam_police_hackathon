# ─── Core ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=trinethra
YOLO_MODEL_PATH=models/best.pt
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=500

# ─── Inference ──────────────────────────────────────────────────
# auto | cuda | cpu
INFERENCE_DEVICE=auto

# ─── Multi-Camera Pipeline ──────────────────────────────────────
MAX_CAMERAS=8
FRAME_QUEUE_SIZE=5
FRAME_SKIP=3
TRACK_LOST_TIMEOUT=10

# ─── OCR Triggering ─────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.4
DETECTION_CONFIDENCE_THRESHOLD=0.25
OCR_INTERVAL=10
MAX_OCR_ATTEMPTS=5
MIN_PLATE_WIDTH=30
MIN_PLATE_HEIGHT=15
MIN_SHARPNESS=50.0

# ─── Deduplication ──────────────────────────────────────────────
DUPLICATE_WINDOW_SECONDS=30
PLATE_SIMILARITY_THRESHOLD=0.8

# ─── Aggregation Scoring Weights (should sum to 1.0) ────────────
DETECTION_WEIGHT=0.15
OCR_WEIGHT=0.35
SHARPNESS_WEIGHT=0.15
VALIDITY_WEIGHT=0.25
TEMPORAL_CONSISTENCY_WEIGHT=0.10

# ─── Storage ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
CROPS_DIR=crops
STOLEN_IMAGES_DIR=stolen_images

# ─── Stolen Vehicle Matching ──────────────────────────────────
STOLEN_MATCH_EXACT_THRESHOLD=0.95
STOLEN_MATCH_FUZZY_THRESHOLD=0.80
STOLEN_ALERT_COOLDOWN_SECONDS=300

# ─── Clone Analysis Scoring Weights ─────────────────────────
CLONE_WEIGHT_PLATE_MATCH=0.25
CLONE_WEIGHT_APPEARANCE_DIFF=0.20
CLONE_WEIGHT_COLOR_DIFF=0.15
CLONE_WEIGHT_CLASS_DIFF=0.15
CLONE_WEIGHT_SPATIAL_TEMPORAL=0.25
CLONE_SUSPICION_THRESHOLD=0.60
CLONE_IMPOSSIBLE_TRAVEL_SPEED_KMH=200.0
CLONE_ANALYSIS_WINDOW_SECONDS=3600

# ─── Security ────────────────────────────────────────────────
API_KEY=trinethra-dev-key-change-in-production
